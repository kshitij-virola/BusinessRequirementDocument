  id                               BigInt                            @id @default(autoincrement())
  token                            String
  created_at                       DateTime?                         @db.Timestamptz(6)
  expires_at                       DateTime                          @db.Timestamptz(6)
  user_id                          String?                           @db.Uuid
  jti                              String                            @unique(map: "token_blacklist_outstandingtoken_jti_hex_d9bdf6f7_uniq") @db.VarChar(255)
  token_blacklist_blacklistedtoken token_blacklist_blacklistedtoken?
  accounts_user                    accounts_user?                    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "token_blacklist_outs_user_id_83bc629a_fk_accounts_")

  @@index([jti], map: "token_blacklist_outstandingtoken_jti_hex_d9bdf6f7_like")
  @@index([user_id], map: "token_blacklist_outstandingtoken_user_id_83bc629a")
}

// ─────────────────────────────────────────────────────────────────────────────
// TROO AI domain (this service's own tables, prefixed troo_ to avoid any
// collision with the ai-theme-generator tables introspected above). Owned and
// migrated by this app via `prisma db push` — never run `db pull` again without
// checking it doesn't clobber these additions.
// ─────────────────────────────────────────────────────────────────────────────

enum TrooRole {
  user
  admin
  superadmin
}

enum TrooOauthProvider {
  google
  github
  microsoft
}

enum TrooSubscriptionPlan {
  free
  pro
  agency
}

enum TrooSubscriptionStatus {
  active
  canceled
  past_due
  trialing
}

enum TrooFramework {
  react
  vue
  angular
  html
  wordpress
}

enum TrooWorkspaceStatus {
  active
  archived
  deleted
}

enum TrooProjectStatus {
  active
  archived
  deleted
}

enum TrooInputMode {
  text
  figma
  image
}

enum TrooGenerationStatus {
  pending
  processing
  completed
  failed
  cancelled
}

enum TrooTokenType {
  refresh
  email_verify
  password_reset
}

model TrooUser {
  id                     String                 @id @default(uuid())
  name                   String
  email                  String                 @unique
  password               String?
  role                   TrooRole               @default(user)
  avatar                 String?
  isEmailVerified        Boolean                @default(false)
  isSuspended            Boolean                @default(false)
  oauthProvider          TrooOauthProvider?
  oauthId                String?
  subscriptionPlan       TrooSubscriptionPlan   @default(free)
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  currentPeriodEnd       DateTime?
  subscriptionStatus     TrooSubscriptionStatus @default(active)
  trialEndsAt            DateTime?
  creditsRemaining       Int                    @default(25)
  creditsUsed            Int                    @default(0)
  creditsResetAt         DateTime               @default(now())
  storageUsedBytes       BigInt                 @default(0)
  storageLimitBytes      BigInt                 @default(524288000)
  permissions            String[]               @default([])
  passwordResetToken     String?
  passwordResetExpires   DateTime?
  emailVerificationToken String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  workspaces  TrooWorkspace[]
  projects    TrooProject[]
  generations TrooGeneration[]
  tokens      TrooToken[]
  auditLogs   TrooAuditLog[]

  @@index([stripeCustomerId])
  @@map("troo_users")
}

model TrooWorkspace {
  id               String              @id @default(uuid())
  userId           String
  user             TrooUser            @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId        String?
  project          TrooProject?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  name             String
  framework        TrooFramework
  status           TrooWorkspaceStatus @default(active)
  description      String?
  currentVersion   Int                 @default(0)
  totalGenerations Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  generations TrooGeneration[]

  @@index([userId, status])
  @@map("troo_workspaces")
}

model TrooProject {
  id             String            @id @default(uuid())
  userId         String
  user           TrooUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  status         TrooProjectStatus @default(active)
  workspaceCount Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  workspaces TrooWorkspace[]

  @@index([userId, status])
  @@map("troo_projects")
}

model TrooGeneration {
  id               String               @id @default(uuid())
  userId           String
  user             TrooUser             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId      String
  workspace        TrooWorkspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  threadId         String?
  projectId        String?
  version          Int
  prompt           String
  framework        TrooFramework
  inputMode        TrooInputMode        @default(text)
  figmaUrl         String?
  imageKey         String?
  imageKeys        String[]             @default([])
  status           TrooGenerationStatus @default(pending)
  outputCode       String?
  outputFiles      Json?
  zipKey           String?
  zipUrl           String?
  tokensUsed       Int                  @default(0)
  creditsUsed      Int                  @default(0)
  aiProvider       String               @default("openai")
  aiModel          String               @default("gpt-4o")
  aiCostUsd        Float                @default(0)
  filesCount       Int?
  errorMessage     String?
  processingTimeMs Int?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([userId, createdAt])
  @@index([workspaceId, version])
  @@map("troo_generations")
}

model TrooPlan {
  id                          String               @id @default(uuid())
  name                        String
  slug                        TrooSubscriptionPlan @unique
  monthlyPrice                Float
  yearlyPrice                 Float
  stripePriceIdMonthly        String?
  stripePriceIdYearly         String?
  featuresProjects            Int
  featuresGenerationsPerMonth Int
  featuresStorageBytes        BigInt
  featuresDownloadsPerMonth   Int?
  featuresFrameworks          String[]             @default([])
  featuresFigmaConversion     Boolean              @default(false)
  featuresImageConversion     Boolean              @default(false)
  featuresTeamMembers         Int                  @default(1)
  featuresApiAccess           Boolean              @default(false)
  featuresPriorityQueue       Boolean              @default(false)
  creditCostTextGeneration    Int                  @default(1)
  creditCostImageConversion   Int                  @default(5)
  creditCostFigmaConversion   Int                  @default(10)
  creditCostThemeExport       Int                  @default(2)
  isActive                    Boolean              @default(true)
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt

  @@map("troo_plans")
}

model TrooConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("troo_configs")
}

model TrooToken {
  id        String        @id @default(uuid())
  userId    String
  user      TrooUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  type      TrooTokenType
  expiresAt DateTime
  createdAt DateTime      @default(now())

  @@index([userId, type])
  @@index([expiresAt])
  @@map("troo_tokens")
}

model TrooAuditLog {
  id         String    @id @default(uuid())
  userId     String?
  user       TrooUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
  actor      String
  actorRole  String
  action     String
  entityId   String?
  entityType String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
  @@map("troo_audit_logs")
}
