  accounts_user_user_permissions   accounts_user_user_permissions[]
  django_admin_log                 django_admin_log[]
  generation_tokenusage            generation_tokenusage[]
  generation_tokenusagesummary     generation_tokenusagesummary[]
  mcp_server_config                mcp_server_config[]
  threads_thread                   threads_thread[]
  token_blacklist_outstandingtoken token_blacklist_outstandingtoken[]

