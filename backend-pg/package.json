{
  "name": "troo-ai-backend-pg",
  "version": "1.0.0",
  "description": "TROO AI Backend-for-Frontend (Postgres/Prisma). Own domain tables (troo_*) plus a read-only view onto the shared ai-theme-generator database.",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:pull": "prisma db pull"
  },
  "keywords": [],
  "license": "ISC",
